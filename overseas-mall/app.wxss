@import './assets/icons/iconfont.wxss';

page {
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', sans-serif;
  font-size: 28rpx;
  color: #2c3e50;
}

/* 图标样式 */
.icon {
  font-family: "iconfont";
  font-size: 32rpx;
  color: #999;
}

.icon.active {
  color: #FF6B4A;
}

.icon-lg {
  font-size: 48rpx;
}

.icon-sm {
  font-size: 24rpx;
}

.container {
  padding: 20rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #FF6B4A 0%, #FF8E6B 100%);
  color: #fff;
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-secondary {
  background: #fff;
  color: #FF6B4A;
  border: 2rpx solid #FF6B4A;
  border-radius: 50rpx;
  padding: 18rpx 38rpx;
  text-align: center;
  font-size: 32rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.text-primary {
  color: #FF6B4A;
}

.text-gray {
  color: #999;
}

.text-bold {
  font-weight: 600;
}

.price {
  color: #FF6B4A;
  font-size: 32rpx;
  font-weight: 600;
}

.price::before {
  content: '$';
  font-size: 24rpx;
}

.divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 20rpx 0;
}

.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
}

.empty-state text {
  color: #999;
  font-size: 28rpx;
}

/* 下拉刷新动画 */
@keyframes pull-refresh {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

.pull-refresh-icon {
  animation: pull-refresh 1s linear infinite;
}

/* 页面过渡动画 */
@keyframes page-fade-in {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes page-slide-in-left {
  from {
    opacity: 0;
    transform: translateX(-100%);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes page-slide-in-right {
  from {
    opacity: 0;
    transform: translateX(100%);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes page-scale-in {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.page-enter {
  animation: page-fade-in 0.3s ease-out;
}

.page-enter-left {
  animation: page-slide-in-left 0.3s ease-out;
}

.page-enter-right {
  animation: page-slide-in-right 0.3s ease-out;
}

.page-enter-scale {
  animation: page-scale-in 0.3s ease-out;
}

/* 按钮点击动画 */
@keyframes btn-press {
  0% {
    transform: scale(1);
  }
  50% {
    transform: scale(0.95);
  }
  100% {
    transform: scale(1);
  }
}

.btn-press {
  animation: btn-press 0.2s ease-out;
}

/* 列表项加载动画 */
@keyframes item-fade-in {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.item-enter {
  animation: item-fade-in 0.4s ease-out;
}

.item-enter-delay-1 {
  animation: item-fade-in 0.4s ease-out 0.1s both;
}

.item-enter-delay-2 {
  animation: item-fade-in 0.4s ease-out 0.2s both;
}

.item-enter-delay-3 {
  animation: item-fade-in 0.4s ease-out 0.3s both;
}
