.skeleton-container {
  padding: 20rpx;
}

.skeleton-item {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.skeleton-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  background: #f0f0f0;
}

.skeleton-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.skeleton-title {
  width: 80%;
  height: 32rpx;
  border-radius: 8rpx;
  background: #f0f0f0;
}

.skeleton-price {
  width: 40%;
  height: 36rpx;
  border-radius: 8rpx;
  background: #f0f0f0;
}

.skeleton-desc {
  width: 60%;
  height: 28rpx;
  border-radius: 8rpx;
  background: #f0f0f0;
}

.skeleton-loading {
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
}

@keyframes skeleton-loading {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}
