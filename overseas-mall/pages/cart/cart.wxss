.cart-container {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
  padding-top: env(safe-area-inset-top);
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.cart-actions {
  display: flex;
  gap: 16rpx;
  padding: 20rpx;
  background: #fff;
  flex-shrink: 0;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333;
}

.action-btn text {
  font-size: 26rpx;
}

.cart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.select-all {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 28rpx;
  color: #333;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkbox.checked {
  background: #FF6B4A;
  border-color: #FF6B4A;
}

.edit-btn {
  color: #FF6B4A;
  font-size: 28rpx;
}

.cart-list {
  flex: 1;
  padding: 20rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  gap: 20rpx;
  transition: all 0.3s ease;
  animation: cartItemSlideIn 0.4s ease forwards;
}

.cart-item.adding {
  animation: cartItemAdd 0.5s ease;
}

.cart-item.removing {
  animation: cartItemRemove 0.4s ease forwards;
}

@keyframes cartItemSlideIn {
  from {
    opacity: 0;
    transform: translateY(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes cartItemAdd {
  0% {
    transform: scale(0.8);
    opacity: 0;
  }
  50% {
    transform: scale(1.05);
    opacity: 1;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

@keyframes cartItemRemove {
  0% {
    transform: translateX(0);
    opacity: 1;
  }
  100% {
    transform: translateX(100%);
    opacity: 0;
  }
}

.goods-info {
  flex: 1;
  display: flex;
  gap: 20rpx;
  min-width: 0;
  overflow: hidden;
}

.goods-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.goods-image:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.goods-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 8rpx;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.4;
}

.goods-spec {
  font-size: 24rpx;
  color: #999;
  line-height: 1.2;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.current-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #FF6B4A;
}

.original-price {
  font-size: 24rpx;
  color: #999;
  text-decoration: line-through;
}

.stock-warning {
  margin-top: 4rpx;
}

.stock-text {
  font-size: 22rpx;
  color: #666;
}

.stock-text.low {
  color: #EF4444;
  font-weight: 500;
}

.quantity-control {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 8rpx;
  overflow: hidden;
  height: 60rpx;
  width: 180rpx;
  flex-shrink: 0;
}

.minus, .plus {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.minus.disabled, .plus.disabled {
  opacity: 0.5;
}

.quantity {
  width: 60rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.3s ease;
}

.animate-increase {
  animation: quantityIncrease 0.3s ease;
}

.animate-decrease {
  animation: quantityDecrease 0.3s ease;
}

@keyframes quantityIncrease {
  0% {
    transform: scale(1);
    color: #333;
  }
  50% {
    transform: scale(1.3);
    color: #FF6B4A;
  }
  100% {
    transform: scale(1);
    color: #333;
  }
}

@keyframes quantityDecrease {
  0% {
    transform: scale(1);
    color: #333;
  }
  50% {
    transform: scale(0.8);
    color: #999;
  }
  100% {
    transform: scale(1);
    color: #333;
  }
}

.delete-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-cart {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon-wrapper {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, #fff5f5 0%, #ffe8e5 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 50rpx;
}

.shop-btn {
  width: 280rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #FF6B4A 0%, #FF8E6B 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(255, 107, 74, 0.3);
}

.shop-btn::after {
  border: none;
}

.cart-footer {
  position: fixed;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  left: 20rpx;
  right: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.12);
  z-index: 10000;
}

.total-info {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.total-label {
  font-size: 28rpx;
  color: #666;
}

.total-price {
  font-size: 36rpx;
  font-weight: 600;
  color: #FF6B4A;
}

.checkout-btn {
  height: 80rpx;
  padding: 0 40rpx;
  background: linear-gradient(135deg, #FF6B4A 0%, #FF8E6B 100%);
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 74, 0.3);
}

.checkout-btn::after {
  border: none;
}

.checkout-btn.disabled {
  background: #ccc;
  box-shadow: none;
}

.merge-tip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 30rpx;
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  margin: 20rpx;
  border-radius: 12rpx;
  flex-wrap: wrap;
}

.merge-tip text {
  font-size: 26rpx;
  color: #92400E;
  flex: 1;
}

.merge-tip-btns {
  display: flex;
  gap: 16rpx;
}

.merge-tip-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.merge-tip-btn-cancel {
  color: #92400E;
  background: rgba(255, 255, 255, 0.5);
}

.merge-tip-btn-confirm {
  color: #fff;
  background: #F59E0B;
}
