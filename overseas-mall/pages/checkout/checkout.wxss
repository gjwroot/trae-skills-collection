.checkout-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  display: flex;
  flex-direction: column;
  padding-top: env(safe-area-inset-top);
  padding-bottom: 200rpx;
}

.main-content {
  flex: 1;
  padding: 24rpx;
}

.address-section {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 32rpx;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  border-left: 6rpx solid #FF6B4A;
}

.address-content {
  flex: 1;
}

.address-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.address-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.address-phone {
  font-size: 26rpx;
  color: #666;
}

.address-detail {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.address-empty {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 28rpx;
  color: #999;
}

.goods-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2c3e50;
  margin-bottom: 28rpx;
  position: relative;
  padding-left: 16rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 24rpx;
  background: linear-gradient(135deg, #FF6B4A 0%, #FF8E6B 100%);
  border-radius: 3rpx;
}

.goods-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.goods-item {
  display: flex;
  gap: 24rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  background: #f8f9fa;
  transition: all 0.3s ease;
}

.goods-item:hover {
  background: #e9ecef;
  transform: translateY(-2rpx);
}

.goods-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.goods-spec {
  font-size: 24rpx;
  color: #999;
}

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price {
  font-size: 28rpx;
  color: #FF6B4A;
  font-weight: 600;
}

.quantity {
  font-size: 24rpx;
  color: #999;
}

.coupon-section {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  position: relative;
}

.remark-section {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.coupon-section .cell {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
}

.remove-coupon {
  padding: 20rpx 30rpx 20rpx 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cell-title {
  font-size: 28rpx;
  color: #333;
}

.cell-value {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.coupon-value {
  font-size: 26rpx;
  color: #999;
}

.coupon-value.active {
  color: #FF6B4A;
}

.remark-input {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  color: #333;
}

.payment-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.payment-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.payment-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.payment-item.active {
  background: #FFF0ED;
  border-color: #FF6B4A;
}

.payment-icon {
  width: 80rpx;
  height: 80rpx;
  background: #fff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.payment-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.payment-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.payment-desc {
  font-size: 24rpx;
  color: #999;
}

.payment-check {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.price-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.price-section .price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.price-section .price-row:last-child {
  margin-bottom: 0;
}

.price-section .price-row.total {
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.price-label {
  font-size: 26rpx;
  color: #666;
}

.price-value {
  font-size: 26rpx;
  color: #333;
}

.price-value.discount {
  color: #FF6B4A;
}

.price-section .price-row.total .price-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #FF6B4A;
}

.bottom-bar {
  position: fixed;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  left: 20rpx;
  right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.12);
  z-index: 10000;
}

.total-info {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.total-label {
  font-size: 28rpx;
  color: #333;
}

.total-price {
  font-size: 36rpx;
  font-weight: 600;
  color: #FF6B4A;
}

.submit-btn {
  background: linear-gradient(135deg, #FF6B4A 0%, #FF8E6B 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  padding: 24rpx 60rpx;
  border-radius: 40rpx;
  border: none;
}

.submit-btn::after {
  border: none;
}
