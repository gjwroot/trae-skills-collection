<view class="coupon-center-container">
  <scroll-view class="main-content" scroll-y="{{true}}">
    <view class="tab-bar">
      <view 
        class="tab-item {{activeTab === 'available' ? 'active' : ''}}" 
        bindtap="switchTab" 
        data-tab="available"
      >
        <text>Available</text>
        <view class="tab-badge" wx:if="{{tabCounts.available > 0}}">{{tabCounts.available}}</view>
      </view>
      <view 
        class="tab-item {{activeTab === 'expiring' ? 'active' : ''}}" 
        bindtap="switchTab" 
        data-tab="expiring"
      >
        <text>Expiring Soon</text>
        <view class="tab-badge" wx:if="{{tabCounts.expiring > 0}}">{{tabCounts.expiring}}</view>
      </view>
      <view 
        class="tab-item {{activeTab === 'claimed' ? 'active' : ''}}" 
        bindtap="switchTab" 
        data-tab="claimed"
      >
        <text>My Coupons</text>
        <view class="tab-badge" wx:if="{{tabCounts.claimed > 0}}">{{tabCounts.claimed}}</view>
      </view>
    </view>

    <view class="coupon-list">
      <view class="coupon-item" wx:for="{{couponList}}" wx:key="id">
        <view class="coupon-left">
          <text class="coupon-amount">${{item.amount}}</text>
          <text class="coupon-condition">Min spend ${{item.minAmount}}</text>
        </view>
        <view class="coupon-right">
          <view class="coupon-info">
            <text class="coupon-name">{{item.name}}</text>
            <text class="coupon-time">{{item.startTime}} - {{item.endTime}}</text>
          </view>
          <button 
            class="claim-btn {{item.claimed ? 'claimed' : ''}}" 
            bindtap="claimCoupon" 
            data-id="{{item.id}}"
            disabled="{{item.claimed}}"
          >
            {{item.claimed ? 'Claimed' : 'Claim'}}
          </button>
        </view>
      </view>
    </view>

    <empty-state 
      wx:if="{{couponList.length === 0 && !loading}}"
      icon="coupon"
      title="No coupons available"
      desc="Check back later for new offers"
      showBtn="{{false}}"
    />

    <view class="loading-state" wx:if="{{loading}}">
      <text>Loading...</text>
    </view>
  </scroll-view>
</view>
