.customer-service-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.message-list {
  flex: 1;
  padding: 20rpx;
}

.message-item {
  display: flex;
  margin-bottom: 30rpx;
  align-items: flex-start;
}

.message-item.self {
  flex-direction: row-reverse;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  margin: 0 20rpx;
  flex-shrink: 0;
}

.avatar-placeholder {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B4A 0%, #FF8E6B 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

.avatar-placeholder.self {
  background: linear-gradient(135deg, #4A90FF 0%, #6BB3FF 100%);
}

.message-content-wrapper {
  flex: 1;
  max-width: 70%;
}

.message-item.self .message-content-wrapper {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.message-bubble {
  padding: 20rpx 30rpx;
  border-radius: 20rpx;
  position: relative;
  word-break: break-word;
}

.message-bubble.other {
  background: #fff;
  color: #333;
  border-top-left-radius: 8rpx;
}

.message-bubble.self {
  background: linear-gradient(135deg, #FF6B4A 0%, #FF8E6B 100%);
  color: #fff;
  border-top-right-radius: 8rpx;
}

.message-text {
  font-size: 30rpx;
  line-height: 1.6;
}

.message-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 10rpx;
  padding: 0 10rpx;
}

.quick-questions {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  border-top-left-radius: 8rpx;
}

.quick-title {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.quick-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.quick-item {
  padding: 15rpx 25rpx;
  background: #f8f8f8;
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #FF6B4A;
  text-align: center;
  transition: all 0.3s;
}

.quick-item:active {
  background: #FF6B4A;
  color: #fff;
}

.typing-indicator {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  border-radius: 20rpx;
  border-top-left-radius: 8rpx;
  width: fit-content;
  margin-left: 120rpx;
  margin-bottom: 30rpx;
}

.typing-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #999;
  margin: 0 4rpx;
  animation: typing 1.4s infinite ease-in-out;
}

.typing-dot:nth-child(1) {
  animation-delay: 0s;
}

.typing-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.typing-dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes typing {
  0%, 80%, 100% {
    transform: scale(0.8);
    opacity: 0.5;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

.input-area {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.input-tools {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.tool-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tool-icon {
  font-size: 40rpx;
}

.input-wrapper {
  flex: 1;
  margin: 0 20rpx;
}

.message-input {
  width: 100%;
  height: 70rpx;
  background: #f5f5f5;
  border-radius: 35rpx;
  padding: 0 25rpx;
  font-size: 28rpx;
}

.send-btn {
  padding: 15rpx 30rpx;
  background: #ddd;
  color: #999;
  border-radius: 30rpx;
  font-size: 28rpx;
  transition: all 0.3s;
}

.send-btn.active {
  background: linear-gradient(135deg, #FF6B4A 0%, #FF8E6B 100%);
  color: #fff;
}
