.flash-sale-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FF6B4A 0%, #FFE0B2 100%);
}

.main-content {
  height: 100vh;
  padding: 20rpx;
}

.header-section {
  margin-bottom: 30rpx;
}

.countdown-box {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 74, 0.2);
}

.countdown-label {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.countdown-timer {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.time-box {
  min-width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #FF6B4A 0%, #FF8A65 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 800;
  color: #fff;
}

.separator {
  font-size: 36rpx;
  font-weight: 800;
  color: #FF6B4A;
}

.tabs-section {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 30rpx;
  gap: 8rpx;
}

.tab-item {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.tab-item text {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.tab-item.active {
  background: linear-gradient(135deg, #FF6B4A 0%, #FF8A65 100%);
}

.tab-item.active text {
  color: #fff;
  font-weight: 600;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.product-item {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  gap: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.product-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.product-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.sale-price {
  font-size: 40rpx;
  font-weight: 800;
  color: #FF6B4A;
}

.original-price {
  font-size: 26rpx;
  color: #999;
  text-decoration: line-through;
}

.progress-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF6B4A 0%, #FF8A65 100%);
  border-radius: 6rpx;
  transition: width 0.3s;
}

.progress-text {
  font-size: 22rpx;
  color: #FF6B4A;
  font-weight: 600;
  min-width: 80rpx;
  text-align: right;
}

.buy-btn {
  width: 100%;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0;
  background: linear-gradient(135deg, #FF6B4A 0%, #FF8A65 100%);
  color: #fff;
  font-size: 26rpx;
  border-radius: 32rpx;
  border: none;
  font-weight: 600;
  margin-top: 8rpx;
}

.buy-btn.disabled {
  background: #ddd;
  color: #999;
}

.buy-btn[disabled] {
  opacity: 1;
}

.empty-state {
  padding: 120rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.empty-state text {
  font-size: 28rpx;
  color: #999;
}
