<view class="forgot-container">
  <view class="custom-nav-bar">
    <view class="nav-bar-content">
      <view class="nav-bar-back" bindtap="navigateToLogin">
        <custom-icon name="arrow-left" size="24px" color="#fff" />
      </view>
      <text class="nav-bar-title">Forgot Password</text>
    </view>
  </view>
  
  <view class="header">
    <text class="title">Forgot Password</text>
    <text class="subtitle">Reset your password</text>
  </view>

  <view class="form-section">
    <view class="input-group">
      <input 
        class="input-field" 
        type="text" 
        placeholder="Phone Number / Email"
        value="{{account}}"
        bindinput="onAccountInput"
      />
    </view>

    <view class="input-group code-group">
      <input 
        class="input-field" 
        type="number" 
        placeholder="Verification Code"
        value="{{code}}"
        bindinput="onCodeInput"
      />
      <button 
        class="code-btn {{countdown > 0 ? 'disabled' : ''}}" 
        bindtap="sendCode"
        disabled="{{countdown > 0}}"
      >
        {{countdown > 0 ? countdown + 's' : 'Get Code'}}
      </button>
    </view>

    <view class="input-group">
      <input 
        class="input-field" 
        type="password" 
        placeholder="New Password"
        value="{{newPassword}}"
        bindinput="onNewPasswordInput"
      />
    </view>

    <view class="input-group">
      <input 
        class="input-field" 
        type="password" 
        placeholder="Confirm New Password"
        value="{{confirmPassword}}"
        bindinput="onConfirmPasswordInput"
      />
    </view>

    <button class="reset-btn" bindtap="handleReset">Reset Password</button>

    <view class="login-link">
      <text>Remember your password? </text>
      <text class="link" bindtap="navigateToLogin">Login</text>
    </view>
  </view>
</view>
