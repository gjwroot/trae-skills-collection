.compare-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-top: env(safe-area-inset-top);
}

.compare-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 30rpx;
  background: #fff;
}

.compare-header .title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.compare-header .sub-title {
  font-size: 26rpx;
  color: #999;
}

.compare-header .clear-btn {
  margin-left: auto;
  font-size: 28rpx;
  color: #FF6B4A;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 150rpx 40rpx;
}

.empty-state .empty-title {
  font-size: 32rpx;
  color: #333;
  margin-top: 30rpx;
  margin-bottom: 16rpx;
}

.empty-state .empty-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.empty-state .go-btn {
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #FF6B4A 0%, #FF8E6B 100%);
  color: #fff;
  border-radius: 50rpx;
  font-size: 28rpx;
  border: none;
}

.empty-state .go-btn::after {
  border: none;
}

.compare-scroll {
  margin: 20rpx;
}

.compare-table {
  display: flex;
  flex-direction: column;
  min-width: 750rpx;
}

.compare-row {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.compare-row:first-child {
  border-radius: 16rpx 16rpx 0 0;
}

.compare-row:last-child {
  border-radius: 0 0 16rpx 16rpx;
  border-bottom: none;
}

.compare-cell {
  flex: 1;
  padding: 30rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 180rpx;
}

.compare-header-cell {
  background: #f9f9f9;
  font-weight: 600;
  color: #333;
  font-size: 28rpx;
  flex: 0 0 150rpx;
  min-width: 150rpx;
}

.compare-item-cell {
  padding: 20rpx;
}

.item-card {
  position: relative;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.item-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  margin-bottom: 16rpx;
}

.item-name {
  font-size: 26rpx;
  color: #333;
  text-align: center;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.4;
}

.remove-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background: #FF6B4A;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.compare-value-cell {
  font-size: 26rpx;
  color: #666;
}

.compare-value-cell.best-value {
  background: #FFF5F5;
  color: #FF6B4A;
  font-weight: 600;
}

.price-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FF6B4A;
}

.sales-text {
  font-size: 24rpx;
  color: #999;
}

.rating-text {
  font-size: 28rpx;
  color: #FFA500;
}

.compare-action-cell {
  padding: 20rpx;
}

.action-btn {
  width: 100%;
  padding: 16rpx;
  background: linear-gradient(135deg, #FF6B4A 0%, #FF8E6B 100%);
  color: #fff;
  border-radius: 8rpx;
  font-size: 26rpx;
  border: none;
}

.action-btn::after {
  border: none;
}

.add-more-tip {
  padding: 30rpx;
  text-align: center;
  font-size: 26rpx;
  color: #999;
}
