.guide-container {
  min-height: 100vh;
  position: relative;
}

.guide-swiper {
  height: 100vh;
}

.guide-page {
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx 200rpx;
}

.guide-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.guide-image {
  width: 500rpx;
  height: 500rpx;
  margin-bottom: 60rpx;
  border-radius: 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
}

.guide-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
}

.guide-description {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.6;
}

.guide-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.dots-container {
  display: flex;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.4);
  transition: all 0.3s ease;
}

.dot.active {
  width: 40rpx;
  border-radius: 8rpx;
  background: #fff;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  width: 100%;
  justify-content: space-between;
}

.skip-btn, .next-btn, .start-btn {
  font-size: 28rpx;
  border-radius: 50rpx;
  border: none;
}

.skip-btn::after, .next-btn::after, .start-btn::after {
  border: none;
}

.skip-btn {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  padding: 20rpx 40rpx;
}

.next-btn {
  background: #fff;
  color: #FF6B4A;
  font-weight: 600;
  padding: 20rpx 40rpx;
}

.start-btn {
  background: #fff;
  color: #FF6B4A;
  font-weight: 600;
  padding: 20rpx 80rpx;
  width: 100%;
}
