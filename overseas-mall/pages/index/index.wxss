.index-container {
  background: #f5f5f5;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  margin: calc(20rpx + env(safe-area-inset-top)) 20rpx 20rpx;
  padding: 20rpx 30rpx;
  border-radius: 50rpx;
}

.search-placeholder {
  color: #999;
  font-size: 28rpx;
  margin-left: 16rpx;
}

.banner-swiper {
  width: calc(100% - 40rpx);
  height: 320rpx;
  margin: 0 20rpx 20rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.banner-item {
  width: 100%;
  height: 100%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  overflow: hidden;
}

.banner-image {
  position: absolute;
  width: 100%;
  height: 100%;
  opacity: 0.3;
}

.banner-content {
  text-align: center;
  color: #fff;
  z-index: 1;
}

.banner-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.banner-subtitle {
  display: block;
  font-size: 32rpx;
  margin-bottom: 24rpx;
  opacity: 0.9;
}

.banner-btn {
  display: inline-block;
  background: #fff;
  color: #FF6B4A;
  padding: 16rpx 40rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.category-nav {
  display: flex;
  justify-content: space-around;
  background: #fff;
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.category-icon-box {
  width: 80rpx;
  height: 80rpx;
  background: #FFF5F3;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.category-name {
  font-size: 24rpx;
  color: #333;
}

.section {
  background: #fff;
  margin-bottom: 20rpx;
  padding: 30rpx 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.countdown {
  display: flex;
  align-items: center;
  color: #FF6B4A;
  font-size: 28rpx;
  font-weight: 600;
}

.countdown text {
  background: #FF6B4A;
  color: #fff;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  min-width: 40rpx;
  text-align: center;
}

.countdown .colon {
  background: transparent;
  color: #FF6B4A;
  padding: 8rpx 4rpx;
}

.more {
  font-size: 26rpx;
  color: #999;
}

.goods-scroll {
  white-space: nowrap;
}

.goods-item {
  display: inline-block;
  width: 240rpx;
  margin-right: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.goods-item:last-child {
  margin-right: 0;
}

.goods-card {
  width: calc(50% - 10rpx);
  display: inline-block;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.goods-card:nth-child(odd) {
  margin-right: 20rpx;
}

.goods-grid {
  display: flex;
  flex-wrap: wrap;
}

.goods-image {
  width: 100%;
  height: 280rpx;
  background: #f5f5f5;
}

.goods-info {
  padding: 20rpx;
}

.goods-name {
  font-size: 26rpx;
  color: #333;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  height: 70rpx;
  line-height: 35rpx;
  margin-bottom: 12rpx;
}

.goods-tags {
  display: flex;
  gap: 8rpx;
  margin-top: 8rpx;
}

.tag {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
}

.tag-primary {
  background: #FFF5F3;
  color: #FF6B4A;
}

.tag-danger {
  background: #FFF5F3;
  color: #FF6B4A;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.current-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #FF6B4A;
}

.original-price {
  font-size: 24rpx;
  color: #999;
  text-decoration: line-through;
}

.sales {
  font-size: 22rpx;
  color: #999;
}

.sales-info {
  position: relative;
  height: 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  overflow: hidden;
  margin-top: 12rpx;
}

.sales-progress {
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  background: #FF6B4A;
  border-radius: 12rpx;
}

.sales-text {
  position: absolute;
  right: 8rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 20rpx;
  color: #FF6B4A;
  font-weight: 600;
}

.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  color: #999;
  font-size: 24rpx;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #FF6B4A;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-right: 16rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
