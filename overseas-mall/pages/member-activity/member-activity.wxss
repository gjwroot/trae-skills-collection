.member-activity-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.page-header {
  position: relative;
  padding: calc(30rpx + env(safe-area-inset-top)) 30rpx 40rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #FF6B4A 0%, #FF8C6B 100%);
}

.user-section {
  position: relative;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  font-weight: 600;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: white;
}

.member-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: white;
  align-self: flex-start;
}

.points-section {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 5rpx;
}

.points-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.points-value {
  font-size: 44rpx;
  font-weight: 700;
  color: white;
}

.tabs {
  display: flex;
  background: white;
  padding: 20rpx 30rpx;
  gap: 40rpx;
  margin-bottom: 20rpx;
}

.tab-item {
  font-size: 30rpx;
  color: #666;
  padding: 10rpx 0;
  position: relative;
}

.tab-item.active {
  color: #FF6B4A;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: #FF6B4A;
  border-radius: 3rpx;
}

.activity-content {
  padding: 0 20rpx;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #FF6B4A;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  color: #999;
  font-size: 28rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

.activity-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.activity-item {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
}

.activity-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon-text {
  font-size: 48rpx;
}

.activity-content-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  min-width: 0;
}

.activity-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 15rpx;
}

.activity-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}

.level-badge {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.activity-desc {
  font-size: 26rpx;
  color: #999;
  line-height: 1.5;
}

.activity-meta {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.activity-time {
  font-size: 24rpx;
  color: #999;
}

.activity-rewards {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.reward-tag {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.reward-tag.points {
  background: #FFF3E0;
  color: #FF9800;
}

.reward-tag.discount {
  background: #E8F5E9;
  color: #4CAF50;
}

.reward-tag.multiplier {
  background: #E3F2FD;
  color: #2196F3;
}

.activity-action {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.action-btn {
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #FF6B4A 0%, #FF8C6B 100%);
  color: white;
  border: none;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.action-btn::after {
  border: none;
}

.action-btn.participated {
  background: #f5f5f5;
  color: #999;
}

.action-btn[disabled] {
  opacity: 0.6;
}
