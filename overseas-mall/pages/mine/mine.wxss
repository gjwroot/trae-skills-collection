.mine-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.user-header {
  background: linear-gradient(135deg, #FF6B4A 0%, #FF8E6B 100%);
  padding: calc(40rpx + env(safe-area-inset-top)) 30rpx 80rpx;
  position: relative;
}

.header-actions {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 20rpx;
}

.message-icon {
  position: relative;
  padding: 10rpx;
}

.message-badge {
  position: absolute;
  top: 2rpx;
  right: 2rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: linear-gradient(135deg, #FF6B4A 0%, #FF4444 100%);
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 74, 0.4);
}

.user-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar-box {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #fff;
}

.user-text {
  flex: 1;
}

.username-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.username {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.vip-badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  border-radius: 30rpx;
}

.vip-badge text {
  font-size: 20rpx;
  font-weight: 600;
  color: #fff;
}

.user-id {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
}

.points-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.points-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

.quick-actions {
  margin: 20rpx;
  position: relative;
  z-index: 20;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16rpx;
}

.action-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  position: relative;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.2s ease;
}

.action-item:active {
  transform: scale(0.96);
}

.action-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.action-icon.sign-in {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.action-icon.coupon {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.action-icon.flash {
  background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
}

.action-icon.vip {
  background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
}

.action-icon.activity {
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
}

.action-label {
  font-size: 22rpx;
  font-weight: 500;
  color: #333;
  text-align: center;
}

.action-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: #FF6B4A;
  color: #fff;
  font-size: 16rpx;
  padding: 4rpx 10rpx;
  border-radius: 16rpx;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 74, 0.4);
}

.vip-progress {
  margin-top: 16rpx;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FFD700 0%, #FFA500 100%);
  border-radius: 4rpx;
  transition: width 0.5s ease;
}

.progress-text {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.9);
}

.stats-section {
  margin: -40rpx 20rpx 20rpx;
  position: relative;
  z-index: 15;
}

.stats-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF6B4A;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #f0f0f0;
}

.order-section {
  background: linear-gradient(145deg, #ffffff 0%, #fafafa 100%);
  margin: 0 20rpx 20rpx;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  position: relative;
  z-index: 10;
  border: 1rpx solid rgba(255, 107, 74, 0.08);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  background: linear-gradient(135deg, #FF6B4A 0%, #FF8E6B 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.view-all {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #FF6B4A;
  font-weight: 500;
}

.order-nav {
  display: flex;
  justify-content: space-around;
  padding: 8rpx 0;
}

.order-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 8rpx;
  border-radius: 20rpx;
  transition: all 0.2s ease;
}

.order-item:active {
  background: rgba(255, 107, 74, 0.08);
  transform: scale(0.95);
}

.order-icon-box {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #FFF5F3 0%, #FFE8E3 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 74, 0.15);
}

.custom-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  background: linear-gradient(135deg, #FF6B4A 0%, #FF4444 100%);
  border-radius: 18rpx;
  font-size: 20rpx;
  color: #fff;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 74, 0.4);
}

.order-item text {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

.service-section,
.settings-section {
  background: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.service-section .section-title,
.settings-section .section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.menu-list {
  display: flex;
  flex-direction: column;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  position: relative;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.logout-section {
  margin: 40rpx 20rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  background: #fff;
  color: #FF6B4A;
  border: 2rpx solid #FF6B4A;
  border-radius: 44rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
