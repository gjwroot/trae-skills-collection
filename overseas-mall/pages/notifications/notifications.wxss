.notifications-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.main-content {
  flex: 1;
  height: 0;
}

.tabs {
  display: flex;
  background: #fff;
  padding: 20rpx 0;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  padding: 16rpx 0;
  position: relative;
  display: flex;
  justify-content: center;
}

.tab-text-wrapper {
  position: relative;
  display: inline-flex;
  align-items: center;
}

.tab-item.active {
  color: #FF6B4A;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #FF6B4A;
  border-radius: 2rpx;
}

.tab-badge {
  position: absolute;
  top: -12rpx;
  right: -16rpx;
  min-width: 28rpx;
  height: 28rpx;
  background: linear-gradient(135deg, #FF6B4A 0%, #FF4444 100%);
  color: #fff;
  font-size: 18rpx;
  font-weight: 600;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 74, 0.4);
}

.notification-list {
  padding: 20rpx;
}

.notification-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  position: relative;
}

.notification-item.read {
  opacity: 0.6;
}

.notification-icon {
  width: 80rpx;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.notification-content {
  flex: 1;
  min-width: 0;
}

.notification-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.notification-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.notification-time {
  font-size: 24rpx;
  color: #999;
}

.notification-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.notification-tag {
  display: inline-block;
  margin-top: 12rpx;
  padding: 4rpx 12rpx;
  background: #FFF0ED;
  color: #FF6B4A;
  font-size: 22rpx;
  border-radius: 6rpx;
}

.unread-dot {
  width: 16rpx;
  height: 16rpx;
  background: #FF6B4A;
  border-radius: 50%;
  position: absolute;
  top: 24rpx;
  right: 24rpx;
}

.bottom-actions {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
  padding: 0;
}

.mark-read-btn {
  background: #f5f5f5;
  color: #666;
}

.clear-btn {
  background: #FFF0ED;
  color: #FF6B4A;
}

.action-btn::after {
  border: none;
}
