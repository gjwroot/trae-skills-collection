.points-rules-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.main-content {
  height: 100vh;
  padding: 20rpx;
}

.points-header {
  margin-bottom: 30rpx;
}

.points-card {
  background: linear-gradient(135deg, #FF6B4A 0%, #FF8A65 100%);
  border-radius: 20rpx;
  padding: 50rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 10rpx 30rpx rgba(255, 107, 74, 0.3);
}

.points-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 10rpx;
}

.points-value {
  font-size: 64rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 20rpx;
}

.points-level {
  padding: 8rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 10rpx;
  border-left: 6rpx solid #FF6B4A;
}

.history-section,
.rules-section {
  margin-bottom: 30rpx;
}

.history-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-item:last-child {
  border-bottom: none;
}

.history-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.history-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.history-time {
  font-size: 22rpx;
  color: #999;
}

.history-points {
  font-size: 32rpx;
  font-weight: 700;
}

.history-points.earn {
  color: #FF6B4A;
}

.history-points.spend {
  color: #333;
}

.empty-state {
  background: #fff;
  border-radius: 20rpx;
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.empty-state text {
  font-size: 26rpx;
  color: #999;
}

.rule-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.rule-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.rule-card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.rule-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rule-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.rule-dot {
  font-size: 28rpx;
  color: #FF6B4A;
  font-weight: 700;
  line-height: 1.5;
}

.rule-text {
  flex: 1;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.checkin-section,
.tasks-section {
  margin-bottom: 30rpx;
}

.checkin-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
}

.checkin-streak {
  text-align: center;
  margin-bottom: 24rpx;
}

.streak-label {
  font-size: 32rpx;
  font-weight: 700;
  color: #FF6B4A;
}

.checkin-calendar {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.calendar-day {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  width: 70rpx;
  height: 90rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
  position: relative;
}

.calendar-day.today {
  border: 2rpx solid #FF6B4A;
  background: #FFF5F3;
}

.calendar-day.checked {
  background: linear-gradient(135deg, #FF6B4A 0%, #FF8E6B 100%);
}

.day-weekday {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
}

.calendar-day.checked .day-weekday,
.calendar-day.checked .day-date {
  color: #fff;
}

.day-date {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
}

.day-check {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 24rpx;
  height: 24rpx;
  background: #10B981;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkin-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #FF6B4A 0%, #FF8E6B 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 74, 0.3);
}

.checkin-btn.checked {
  background: #10B981;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.3);
}

.checkin-btn::after {
  border: none;
}

.tasks-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.task-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.task-item:last-child {
  border-bottom: none;
}

.task-item.completed {
  opacity: 0.6;
}

.task-icon {
  width: 64rpx;
  height: 64rpx;
  background: #FFF5F3;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.task-item.completed .task-icon {
  background: #ECFDF5;
}

.task-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.task-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.task-points {
  font-size: 22rpx;
  color: #FF6B4A;
  font-weight: 600;
}

.task-item.completed .task-points {
  color: #10B981;
}

.task-status {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
