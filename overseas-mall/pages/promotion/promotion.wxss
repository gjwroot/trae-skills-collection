.promotion-container {
  min-height: 100vh;
  background: #f5f5f5;
}

.promotion-header {
  position: relative;
  height: 400rpx;
  overflow: hidden;
}

.promotion-image {
  width: 100%;
  height: 100%;
}

.promotion-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 107, 74, 0.9) 0%, rgba(255, 142, 107, 0.9) 100%);
}

.promotion-info {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
  color: #fff;
  width: 80%;
}

.promotion-title {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.promotion-subtitle {
  display: block;
  font-size: 36rpx;
  margin-bottom: 20rpx;
  opacity: 0.95;
}

.promotion-desc {
  display: block;
  font-size: 26rpx;
  opacity: 0.85;
  line-height: 1.5;
}

.goods-section {
  padding: 20rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.goods-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.goods-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.goods-image {
  width: 100%;
  height: 320rpx;
  background: #f5f5f5;
}

.goods-info {
  padding: 20rpx;
}

.goods-name {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  font-size: 26rpx;
  color: #333;
  line-height: 1.4;
  margin-bottom: 12rpx;
  height: 72rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.current-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #FF6B4A;
}

.original-price {
  font-size: 24rpx;
  color: #999;
  text-decoration: line-through;
}

.loading,
.no-more,
.empty {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}
