.refund-apply-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.main-content {
  flex: 1;
  height: 0;
  padding: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.order-info-section,
.goods-section,
.refund-type-section,
.reason-section,
.amount-section,
.desc-section,
.images-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.order-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.order-no,
.order-time {
  font-size: 26rpx;
  color: #666;
}

.goods-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.goods-item {
  display: flex;
  gap: 20rpx;
}

.goods-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.goods-spec {
  font-size: 24rpx;
  color: #999;
}

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price {
  font-size: 28rpx;
  color: #FF6B4A;
  font-weight: 600;
}

.quantity {
  font-size: 24rpx;
  color: #999;
}

.type-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.type-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 12rpx;
  background: #fafafa;
}

.type-item.active {
  border-color: #FF6B4A;
  background: #FFF0ED;
}

.type-icon {
  width: 64rpx;
  height: 64rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.type-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.type-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.type-desc {
  font-size: 24rpx;
  color: #999;
}

.reason-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.reason-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 12rpx;
  background: #fafafa;
  font-size: 28rpx;
  color: #333;
}

.reason-item.active {
  border-color: #FF6B4A;
  background: #FFF0ED;
  color: #FF6B4A;
}

.amount-input-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.currency {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.amount-input {
  flex: 1;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.amount-tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

.desc-input {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.char-count {
  font-size: 24rpx;
  color: #999;
  text-align: right;
  margin-top: 12rpx;
}

.images-section .section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.image-count {
  font-size: 24rpx;
  color: #999;
  font-weight: normal;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.image-item .image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.delete-btn {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-btn {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: #fafafa;
}

.upload-btn text {
  font-size: 24rpx;
  color: #999;
}

.bottom-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
}

.refund-summary {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.refund-label {
  font-size: 26rpx;
  color: #666;
}

.refund-amount {
  font-size: 36rpx;
  font-weight: 600;
  color: #FF6B4A;
}

.submit-btn {
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #FF6B4A 0%, #FF8E6B 100%);
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  opacity: 0.5;
}
