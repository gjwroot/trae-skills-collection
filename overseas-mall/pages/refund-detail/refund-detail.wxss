.refund-detail-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.status-section {
  background: linear-gradient(135deg, #FF6B4A 0%, #FF8E6B 100%);
  padding: 80rpx 30rpx 60rpx;
  text-align: center;
}

.status-icon {
  margin-bottom: 20rpx;
}

.status-text {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
}

.status-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.refund-info {
  padding: 30rpx;
}

.info-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.info-value.price {
  color: #FF6B4A;
  font-size: 32rpx;
  font-weight: 600;
}

.goods-section {
  padding: 0 30rpx 30rpx;
}

.goods-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  gap: 20rpx;
}

.goods-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.goods-spec {
  font-size: 24rpx;
  color: #999;
}

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
}

.price {
  font-size: 32rpx;
  color: #FF6B4A;
  font-weight: 600;
}

.quantity {
  font-size: 26rpx;
  color: #999;
}

.timeline-section {
  padding: 0 30rpx 30rpx;
}

.timeline {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.timeline-item {
  display: flex;
  gap: 20rpx;
  padding-bottom: 40rpx;
  position: relative;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #fff;
  border: 2rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  z-index: 1;
}

.timeline-dot.completed {
  border-color: #FF6B4A;
  background: rgba(255, 107, 74, 0.1);
}

.timeline-line {
  position: absolute;
  left: 19rpx;
  top: 40rpx;
  bottom: 0;
  width: 2rpx;
  background: #f0f0f0;
}

.timeline-line.completed {
  background: #FF6B4A;
}

.timeline-item:last-child .timeline-line {
  display: none;
}

.timeline-content {
  flex: 1;
  padding-top: 4rpx;
}

.timeline-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.timeline-time {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.timeline-desc {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

.action-section {
  padding: 20rpx 30rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.view-all-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #FF6B4A 0%, #FF8E6B 100%);
  color: #fff;
  border: none;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cancel-btn {
  width: 100%;
  height: 88rpx;
  background: #fff;
  color: #999;
  border: 2rpx solid #ddd;
  border-radius: 44rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
