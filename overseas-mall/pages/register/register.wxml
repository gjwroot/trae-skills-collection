<view class="register-container">
  <view class="custom-nav-bar">
    <view class="nav-bar-content">
      <view class="nav-bar-back" bindtap="navigateToLogin">
        <custom-icon name="arrow-left" size="24px" color="#fff" />
      </view>
      <text class="nav-bar-title">Create Account</text>
    </view>
  </view>
  
  <view class="header">
    <text class="title">Create Account</text>
    <text class="subtitle">Join Overseas Mall today</text>
  </view>

  <view class="form-section">
    <view class="input-group">
      <input 
        class="input-field" 
        type="text" 
        placeholder="Phone Number / Email"
        value="{{account}}"
        bindinput="onAccountInput"
      />
    </view>

    <view class="input-group">
      <input 
        class="input-field" 
        type="password" 
        placeholder="Password"
        value="{{password}}"
        bindinput="onPasswordInput"
      />
      <view class="password-strength" wx:if="{{password}}">
        <view class="strength-bars">
          <view class="strength-bar" style="background: {{passwordStrength.level >= 1 ? passwordStrength.color : '#E5E5E5'}}"></view>
          <view class="strength-bar" style="background: {{passwordStrength.level >= 2 ? passwordStrength.color : '#E5E5E5'}}"></view>
          <view class="strength-bar" style="background: {{passwordStrength.level >= 3 ? passwordStrength.color : '#E5E5E5'}}"></view>
        </view>
        <text class="strength-text" style="color: {{passwordStrength.color}}">{{passwordStrength.text}}</text>
      </view>
    </view>

    <view class="input-group">
      <input 
        class="input-field {{confirmError ? 'error' : ''}}" 
        type="password" 
        placeholder="Confirm Password"
        value="{{confirmPassword}}"
        bindinput="onConfirmPasswordInput"
      />
      <text class="error-text" wx:if="{{confirmError}}">{{confirmError}}</text>
    </view>

    <view class="input-group code-group">
      <input 
        class="input-field" 
        type="number" 
        placeholder="Verification Code"
        value="{{code}}"
        bindinput="onCodeInput"
      />
      <button 
        class="code-btn {{countdown > 0 ? 'disabled' : ''}}" 
        bindtap="sendCode"
        disabled="{{countdown > 0}}"
      >
        {{countdown > 0 ? countdown + 's' : 'Get Code'}}
      </button>
    </view>

    <view class="agreement">
      <checkbox checked="{{agreed}}" bindtap="toggleAgreement" color="#FF6B4A" />
      <text class="agreement-text">I agree to the </text>
      <text class="link" bindtap="viewTerms">Terms of Service</text>
      <text> and </text>
      <text class="link" bindtap="viewPrivacy">Privacy Policy</text>
    </view>

    <button class="register-btn" bindtap="handleRegister">Create Account</button>

    <view class="login-link">
      <text>Already have an account? </text>
      <text class="link" bindtap="navigateToLogin">Login</text>
    </view>
  </view>
</view>
