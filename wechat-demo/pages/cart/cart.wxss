.container {
  min-height: 100vh;
  background: #f8f9fa;
}

/* 标签栏 */
.tab-header {
  display: flex;
  background: #ffffff;
  padding: 0 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 32rpx 0;
  position: relative;
}

.tab-text {
  font-size: 30rpx;
  color: #636e72;
  font-weight: 500;
}

.tab-item.active .tab-text {
  color: #ff6b4a;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: linear-gradient(135deg, #ff6b4a 0%, #ff8a6d 100%);
  border-radius: 2rpx;
}

.tab-badge {
  background: #ff6b4a;
  color: white;
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  min-width: 32rpx;
  text-align: center;
}

/* 内容区域 */
.content-area {
  padding: 24rpx 32rpx;
  padding-bottom: 160rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon-wrapper {
  width: 200rpx;
  height: 200rpx;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 40rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-icon-img {
  width: 100rpx;
  height: 100rpx;
}

.empty-title {
  font-size: 32rpx;
  color: #1a1a1a;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #636e72;
  margin-bottom: 40rpx;
}

.empty-btn {
  background: linear-gradient(135deg, #ff6b4a 0%, #ff8a6d 100%);
  color: white;
  padding: 24rpx 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 74, 0.3);
}

/* 购物车列表 */
.cart-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.cart-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.cart-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.cart-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.cart-name {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 600;
}

.cart-desc {
  font-size: 24rpx;
  color: #636e72;
  margin-top: 8rpx;
}

.cart-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.cart-price {
  font-size: 32rpx;
  color: #ff6b4a;
  font-weight: 700;
}

/* 数量控制 */
.quantity-control {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.qty-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

.qty-btn.minus {
  background: #f8f9fa;
  color: #636e72;
  border: 2rpx solid #dfe6e9;
}

.qty-btn.plus {
  background: linear-gradient(135deg, #ff6b4a 0%, #ff8a6d 100%);
  color: white;
}

.qty-num {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 600;
  min-width: 40rpx;
  text-align: center;
}

/* 结算栏 */
.checkout-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.total-section {
  display: flex;
  flex-direction: column;
}

.total-label {
  font-size: 24rpx;
  color: #636e72;
  margin-bottom: 4rpx;
}

.total-price-wrapper {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.total-symbol {
  font-size: 28rpx;
  color: #ff6b4a;
  font-weight: 600;
}

.total-price {
  font-size: 44rpx;
  color: #ff6b4a;
  font-weight: 700;
}

.checkout-btn {
  background: linear-gradient(135deg, #ff6b4a 0%, #ff8a6d 100%);
  padding: 24rpx 56rpx;
  border-radius: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 74, 0.3);
}

.checkout-text {
  color: white;
  font-size: 28rpx;
  font-weight: 600;
}

/* 订单列表 */
.order-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.order-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.order-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.order-id {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 600;
}

.order-time {
  font-size: 24rpx;
  color: #636e72;
}

.order-status-tag {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.order-status-tag.completed {
  background: #e8f5e9;
  color: #00b894;
}

.order-status-tag.pending {
  background: #fff5f3;
  color: #ff6b4a;
}

.divider {
  height: 2rpx;
  background: #f1f3f4;
  margin: 24rpx 0;
}

.order-items {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.order-item-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.order-item-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.order-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.order-item-name {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 500;
}

.order-item-price {
  font-size: 24rpx;
  color: #636e72;
}

.order-item-qty {
  font-size: 26rpx;
  color: #636e72;
  font-weight: 500;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 24rpx;
}

.order-total-label {
  font-size: 26rpx;
  color: #636e72;
}

.order-total-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.order-total-price {
  font-size: 36rpx;
  color: #ff6b4a;
  font-weight: 700;
}
