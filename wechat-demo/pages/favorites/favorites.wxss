.container {
  min-height: 100vh;
  background: #fef7ed;
  padding: 20rpx;
  padding-bottom: 40rpx;
}

.empty-section {
  text-align: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 20rpx;
  display: block;
}

.go-menu-btn {
  background: #f97316;
  color: white;
  margin-top: 30rpx;
  padding: 24rpx 60rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: inline-block;
}

.favorites-list {
  padding-bottom: 20rpx;
}

.menu-item {
  background: white;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.1);
}

.item-header {
  position: relative;
  display: flex;
}

.item-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.favorite-btn {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  width: 60rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.item-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
}

.item-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.item-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.item-bottom {
  margin-top: auto;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #f97316;
}

.add-cart-btn {
  background: #f97316;
  color: white;
  padding: 14rpx 28rpx;
  border-radius: 50rpx;
  font-size: 24rpx;
  font-weight: 600;
}
