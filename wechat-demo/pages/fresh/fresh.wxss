.container {
  min-height: 100vh;
  background: #faf6f2;
  padding-bottom: 60rpx;
}

/* 顶部 */
.hero-section {
  background: linear-gradient(135deg, #66bb6a 0%, #43a047 100%);
  padding: 80rpx 30rpx 60rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.hero-content {
  text-align: center;
}

.hero-title {
  font-size: 44rpx;
  color: white;
  font-weight: 700;
}

.hero-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 12rpx;
  display: block;
}

/* 分类 */
.category-section {
  padding: 40rpx 0 20rpx;
}

.section-title {
  padding: 0 30rpx 20rpx;
}

.title {
  font-size: 32rpx;
  color: #2d2d2d;
  font-weight: 600;
}

.category-scroll {
  white-space: nowrap;
  padding: 0 30rpx;
}

.category-item {
  display: inline-block;
  padding: 16rpx 36rpx;
  margin-right: 16rpx;
  background: white;
  border-radius: 48rpx;
  font-size: 26rpx;
  color: #666;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.category-item.active {
  background: linear-gradient(135deg, #66bb6a 0%, #43a047 100%);
  color: white;
  font-weight: 600;
}

/* 食材列表 */
.items-section {
  padding: 20rpx 0;
}

.items-grid {
  padding: 0 30rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.item-card {
  width: calc(50% - 10rpx);
  background: white;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.item-image {
  width: 100%;
  height: 240rpx;
  display: block;
}

.item-info {
  padding: 20rpx;
}

.item-name {
  font-size: 28rpx;
  color: #2d2d2d;
  font-weight: 600;
}

.item-tag {
  font-size: 20rpx;
  color: #66bb6a;
  margin-top: 8rpx;
}

.item-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.item-price {
  display: flex;
  align-items: baseline;
}

.currency {
  font-size: 24rpx;
  color: #43a047;
  font-weight: 600;
}

.price {
  font-size: 32rpx;
  color: #43a047;
  font-weight: 700;
}

.unit {
  font-size: 22rpx;
  color: #8c8c8c;
}

/* 数量控制 */
.quantity-control {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.quantity-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

.quantity-btn.minus {
  background: #f5f5f5;
  color: #666;
}

.quantity-btn.plus {
  background: linear-gradient(135deg, #66bb6a 0%, #43a047 100%);
  color: white;
}

.quantity {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d2d2d;
  min-width: 40rpx;
  text-align: center;
}

/* 品质保证 */
.quality-section {
  margin: 40rpx 30rpx 0;
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.quality-title {
  font-size: 28rpx;
  color: #2d2d2d;
  font-weight: 600;
  text-align: center;
  margin-bottom: 24rpx;
}

.quality-list {
  display: flex;
  justify-content: space-around;
}

.quality-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.quality-icon-wrapper {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.quality-icon-wrapper.fresh-bg {
  background: #e8f5e9;
}

.quality-icon-wrapper.source-bg {
  background: #e3f2fd;
}

.quality-icon-wrapper.check-bg {
  background: #fff8e1;
}

.quality-icon {
  width: 40rpx;
  height: 40rpx;
}

.quality-text {
  font-size: 22rpx;
  color: #666;
}
