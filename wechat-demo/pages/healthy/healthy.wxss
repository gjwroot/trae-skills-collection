.container {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 40rpx;
}

/* 顶部横幅 */
.hero-section {
  background: linear-gradient(135deg, #66bb6a 0%, #43a047 100%);
  padding: 60rpx 40rpx;
  border-radius: 0 0 32rpx 32rpx;
}

.hero-content {
  text-align: center;
}

.hero-title {
  font-size: 48rpx;
  color: white;
  font-weight: 700;
  display: block;
  margin-bottom: 12rpx;
}

.hero-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 菜品区域 */
.foods-section {
  margin: 32rpx;
}

.section-title {
  margin-bottom: 24rpx;
}

.title {
  font-size: 32rpx;
  color: #1a1a1a;
  font-weight: 700;
}

.food-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.food-card {
  background: white;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.food-image {
  width: 100%;
  height: 320rpx;
}

.food-info {
  padding: 24rpx;
}

.food-name {
  font-size: 32rpx;
  color: #1a1a1a;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.food-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.tag {
  padding: 6rpx 16rpx;
  background: #e8f5e9;
  color: #43a047;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.food-desc {
  font-size: 26rpx;
  color: #636e72;
  margin-bottom: 20rpx;
}

.food-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.calories {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #ff6b4a;
  font-weight: 500;
}

.calories-icon {
  width: 32rpx;
  height: 32rpx;
}

.order-btn {
  background: linear-gradient(135deg, #ff6b4a 0%, #ff8a6d 100%);
  color: white;
  padding: 16rpx 36rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 74, 0.3);
  position: relative;
  z-index: 10;
}

/* 数量控制 */
.quantity-control {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.quantity-btn {
  width: 48rpx;
  height: 48rpx;
  background: #f8f9fa;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 600;
}

.quantity-btn.plus {
  background: linear-gradient(135deg, #ff6b4a 0%, #ff8a6d 100%);
  color: white;
}

.quantity {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  min-width: 40rpx;
  text-align: center;
}

/* 营养小贴士 */
.nutrition-section {
  margin: 32rpx;
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.nutrition-title {
  font-size: 32rpx;
  color: #1a1a1a;
  font-weight: 700;
  margin-bottom: 24rpx;
}

.nutrition-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.nutrition-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.nutrition-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nutrition-icon {
  width: 40rpx;
  height: 40rpx;
}

.nutrition-text {
  font-size: 28rpx;
  color: #636e72;
}
