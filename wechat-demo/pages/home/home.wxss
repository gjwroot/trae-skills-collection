.container {
  background: #f8f9fa;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 顶部横幅 */
.hero-section {
  background: linear-gradient(135deg, #ff6b4a 0%, #ff8a6d 100%);
  padding: 60rpx 40rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.hero-content {
  text-align: center;
}

.hero-title {
  font-size: 48rpx;
  color: white;
  font-weight: 700;
  display: block;
  margin-bottom: 16rpx;
}

.hero-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 家常菜区域 */
.homefoods-section {
  margin: 32rpx;
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  margin-bottom: 24rpx;
}

.title {
  font-size: 32rpx;
  color: #1a1a1a;
  font-weight: 700;
}

.homefood-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.homefood-card {
  background: #f8f9fa;
  border-radius: 20rpx;
  overflow: hidden;
}

.homefood-image {
  width: 100%;
  height: 280rpx;
}

.homefood-info {
  padding: 24rpx;
}

.homefood-name {
  font-size: 32rpx;
  color: #1a1a1a;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.homefood-story {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.homefood-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.homefood-price {
  font-size: 36rpx;
  color: #ff6b4a;
  font-weight: 700;
}

/* 数量控制 */
.quantity-control {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.quantity-btn {
  width: 48rpx;
  height: 48rpx;
  background: #f8f9fa;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 600;
}

.quantity-btn.plus {
  background: linear-gradient(135deg, #ff6b4a 0%, #ff8a6d 100%);
  color: white;
}

.quantity {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  min-width: 40rpx;
  text-align: center;
}

/* 回忆区域 */
.memory-section {
  margin: 32rpx;
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.memory-title {
  font-size: 32rpx;
  color: #1a1a1a;
  font-weight: 700;
  margin-bottom: 24rpx;
}

.memory-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.memory-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
}

.memory-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.memory-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #ff6b4a 0%, #ff8a6d 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.memory-emoji {
  font-size: 40rpx;
}

.memory-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.memory-name {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 600;
}

.memory-price {
  font-size: 26rpx;
  color: #ff6b4a;
  font-weight: 600;
}
