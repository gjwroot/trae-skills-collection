.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #fff8f5 0%, #ffffff 100%);
  display: flex;
  flex-direction: column;
  padding: 0 60rpx;
  box-sizing: border-box;
}

/* 顶部区域 */
.header-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80rpx;
  padding-bottom: 60rpx;
}

.logo-wrapper {
  margin-bottom: 30rpx;
}

.logo-icon {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #ff6b4a 0%, #ff8a65 100%);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 74, 0.3);
}

.logo-text {
  font-size: 72rpx;
  font-weight: bold;
  color: #ffffff;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999999;
  letter-spacing: 4rpx;
}

/* 表单区域 */
.form-section {
  flex: 1;
}

.form-item {
  margin-bottom: 30rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  background: #ffffff;
  border: 2rpx solid #f0f0f0;
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 100rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.input-label {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  margin-right: 20rpx;
  padding-right: 20rpx;
  border-right: 2rpx solid #f0f0f0;
}

.phone-input {
  flex: 1;
  height: 100rpx;
  font-size: 32rpx;
  color: #333333;
  line-height: 100rpx;
}

.code-wrapper {
  padding-right: 0;
}

.code-input {
  flex: 1;
  height: 100rpx;
  font-size: 32rpx;
  color: #333333;
  padding-left: 24rpx;
  line-height: 100rpx;
}

.placeholder {
  color: #cccccc;
  font-size: 30rpx;
}

.code-btn {
  height: 76rpx;
  line-height: 76rpx;
  padding: 0 28rpx;
  background: transparent;
  border: none;
  border-left: 2rpx solid #f0f0f0;
  color: #ff6b4a;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 0;
  margin: 0;
}

.code-btn.disabled {
  color: #cccccc;
}

.code-btn::after {
  border: none;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #ff6b4a 0%, #ff8a65 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 48rpx;
  margin-top: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 74, 0.3);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-btn.disabled {
  background: #cccccc;
  box-shadow: none;
}

.login-btn::after {
  border: none;
}

/* 分割线 */
.divider {
  display: flex;
  align-items: center;
  margin: 50rpx 0;
}

.line {
  flex: 1;
  height: 2rpx;
  background: #f0f0f0;
}

.divider-text {
  padding: 0 24rpx;
  font-size: 24rpx;
  color: #999999;
}

/* 快捷登录按钮 */
.wechat-btn,
.phone-btn {
  width: 100%;
  height: 96rpx;
  background: #ffffff;
  border: 2rpx solid #e8e8e8;
  border-radius: 48rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding: 0 14rpx;
}

.wechat-btn::after,
.phone-btn::after {
  border: none;
}

.btn-content {
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.icon-wrapper {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.login-icon {
  width: 40rpx;
  height: 40rpx;
}

.btn-text {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

/* 底部协议 */
.footer {
  padding: 40rpx 0 60rpx;
}

.agreement {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
}

.agree-checkbox {
  transform: scale(0.7);
  margin-right: 8rpx;
}

.agree-text {
  font-size: 24rpx;
  color: #999999;
}

.link {
  font-size: 24rpx;
  color: #ff6b4a;
  margin: 0 4rpx;
}
