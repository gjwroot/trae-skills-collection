.container {
  min-height: 100vh;
  background: #f8f9fa;
  padding: 0 32rpx 40rpx;
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #ff6b4a 0%, #ff8a6d 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-top: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 74, 0.3);
}

.user-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 40rpx;
}

.avatar-section {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-wrapper {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.avatar-icon {
  width: 64rpx;
  height: 64rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 40rpx;
  color: #ffffff;
  font-weight: 700;
}

.user-level {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
  align-self: flex-start;
}

.settings-btn {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.settings-icon {
  width: 40rpx;
  height: 40rpx;
}

/* 统计数据 */
.stats-section {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-num {
  font-size: 40rpx;
  color: #ffffff;
  font-weight: 700;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.2);
}

/* 功能菜单 */
.menu-section {
  margin-bottom: 32rpx;
}

.menu-title {
  font-size: 32rpx;
  color: #1a1a1a;
  font-weight: 700;
  margin-bottom: 24rpx;
}

.menu-list {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid #f8f9fa;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.menu-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-icon-img {
  width: 32rpx;
  height: 32rpx;
}

.order-icon {
  background: #fff5f3;
}

.fav-icon {
  background: #fff9e6;
}

.addr-icon {
  background: #e8f5e9;
}

.cart-icon {
  background: #e3f2fd;
}

.clear-icon {
  background: #f5f5f5;
}

.about-icon {
  background: #f3e5f5;
}

.menu-text {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 500;
}

.menu-arrow {
  font-size: 32rpx;
  color: #b2bec3;
}

/* 底部信息 */
.footer {
  text-align: center;
  padding: 40rpx 0;
}

.footer-text {
  font-size: 24rpx;
  color: #b2bec3;
  display: block;
}

.footer-slogan {
  font-size: 26rpx;
  color: #ff6b4a;
  margin-top: 12rpx;
  display: block;
  font-weight: 500;
}
