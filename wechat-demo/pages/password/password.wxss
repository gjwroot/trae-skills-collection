.container {
  min-height: 100vh;
  background: #f8f9fa;
  padding: 0 32rpx 40rpx;
}

/* 页面标题 */
.page-header {
  padding: 32rpx 0;
  text-align: center;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
}

/* 表单区域 */
.form-section {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  margin-top: 32rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid #f8f9fa;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  width: 160rpx;
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 500;
}

.form-input {
  flex: 1;
  font-size: 30rpx;
  color: #1a1a1a;
}

/* 提示信息 */
.tips-section {
  margin-top: 32rpx;
  padding: 0 16rpx;
}

.tips-text {
  font-size: 26rpx;
  color: #636e72;
}

/* 保存按钮 */
.save-section {
  margin-top: 48rpx;
}

.save-btn {
  background: linear-gradient(135deg, #ff6b4a 0%, #ff8a6d 100%);
  color: white;
  text-align: center;
  padding: 32rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 74, 0.3);
}
