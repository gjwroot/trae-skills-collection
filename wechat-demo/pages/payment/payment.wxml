<view class="container">
  <!-- 支付限制说明 -->
  <view class="warning-box">
    <view class="warning-title">⚠️ 支付功能限制</view>
    <view class="warning-item">1. 个人小程序无法开通支付功能</view>
    <view class="warning-item">2. 需要企业资质和对应类目</view>
    <view class="warning-item">3. 支付参数必须从后端获取</view>
    <view class="warning-item">4. 开发者工具无法真实支付</view>
  </view>

  <view class="order-info">
    <view class="order-title">订单信息</view>
    <view class="order-item">
      <text>订单编号：</text>
      <text>{{orderId || 'TEST202403080001'}}</text>
    </view>
    <view class="order-item">
      <text>订单金额：</text>
      <text class="price">¥{{totalPrice || '99.00'}}</text>
    </view>
  </view>

  <view class="payment-methods">
    <view class="section-title">支付方式</view>

    <view class="method-item {{selectedMethod === 'wechat' ? 'active' : ''}}" bindtap="selectMethod" data-method="wechat">
      <view class="method-info">
        <view class="method-icon wechat-icon">
          <image src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%2307c160'%3E%3Cpath d='M8.5 13.5a1.5 1.5 0 100-3 1.5 1.5 0 000 3zM15.5 13.5a1.5 1.5 0 100-3 1.5 1.5 0 000 3z'/%3E%3Cpath fill-rule='evenodd' d='M12 2C6.48 2 2 6.48 2 12c0 1.82.38 3.55 1.07 5.12.1.24.04.52-.15.7l-1.6 1.6c-.2.2-.06.54.22.54h.17c4.42 0 8.36-2.1 10.9-5.36A9.96 9.96 0 0022 12c0-5.52-4.48-10-10-10zm-5.5 7a1.5 1.5 0 100 3 1.5 1.5 0 000-3zm7 0a1.5 1.5 0 100 3 1.5 1.5 0 000-3z' clip-rule='evenodd'/%3E%3C/svg%3E" mode="aspectFit"></image>
        </view>
        <view class="method-text">
          <text class="method-name">微信支付</text>
          <text class="method-desc">推荐使用</text>
        </view>
      </view>
      <view class="radio {{selectedMethod === 'wechat' ? 'checked' : ''}}"></view>
    </view>

    <view class="method-item {{selectedMethod === 'alipay' ? 'active' : ''}}" bindtap="selectMethod" data-method="alipay">
      <view class="method-info">
        <view class="method-icon alipay-icon">
          <image src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%231677ff'%3E%3Cpath d='M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 15h-2v-2h2v2zm0-4h-2V7h2v6zm4 4h-2v-2h2v2zm0-4h-2V7h2v6z'/%3E%3C/svg%3E" mode="aspectFit"></image>
        </view>
        <view class="method-text">
          <text class="method-name">支付宝</text>
          <text class="method-desc">暂不支持</text>
        </view>
      </view>
      <view class="radio {{selectedMethod === 'alipay' ? 'checked' : ''}}"></view>
    </view>
  </view>

  <!-- 支付流程说明 -->
  <view class="flow-box">
    <view class="flow-title">支付流程</view>
    <view class="flow-steps">
      <view class="step">
        <view class="step-num">1</view>
        <text class="step-text">前端调用支付</text>
      </view>
      <view class="step-arrow">→</view>
      <view class="step">
        <view class="step-num">2</view>
        <text class="step-text">后端生成订单</text>
      </view>
      <view class="step-arrow">→</view>
      <view class="step">
        <view class="step-num">3</view>
        <text class="step-text">调起微信支付</text>
      </view>
    </view>
  </view>

  <view class="bottom-bar">
    <view class="total">
      <text>总计：</text>
      <text class="total-price">¥{{totalPrice || '99.00'}}</text>
    </view>
    <button class="pay-btn" bindtap="pay">立即支付</button>
  </view>
</view>