.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 警告框 */
.warning-box {
  background: #fffbe6;
  border: 2rpx solid #ffe58f;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 20rpx;
}

.warning-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #d48806;
  margin-bottom: 12rpx;
}

.warning-item {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

/* 区块 */
.section {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  padding: 24rpx 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

/* 权限按钮 - 获取手机号 */
.permission-btn {
  width: 100%;
  background: #fff;
  border: none;
  border-bottom: 2rpx solid #f5f5f5;
  padding: 0;
  margin: 0;
  text-align: left;
}

.permission-btn::after {
  border: none;
}

.permission-content {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
}

/* 权限项 */
.permission-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.permission-item:last-child {
  border-bottom: none;
}

.permission-icon {
  width: 56rpx;
  height: 56rpx;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.permission-icon image {
  width: 100%;
  height: 100%;
}

.permission-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.permission-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.permission-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* 原生组件 */
.component-item {
  padding: 24rpx 30rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.component-item:last-child {
  border-bottom: none;
}

.component-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.component-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.component-tip {
  font-size: 22rpx;
  color: #ff6b4a;
  background: #fff8f5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* 权限状态 */
.status-list {
  padding: 0 30rpx;
}

.status-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.status-item:last-child {
  border-bottom: none;
}

.status-name {
  font-size: 28rpx;
  color: #333;
}

.status-value {
  font-size: 26rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.status-value.granted {
  color: #52c41a;
  background: #f6ffed;
}

.status-value.denied {
  color: #999;
  background: #f5f5f5;
}
